# --- Google Cloud / Vertex AI (Gemini) ---
# Replace GOOGLE_CLOUD_PROJECT with your GCP project ID (from Cloud Console).
# Vertex only — no Gemini API key. Point GOOGLE_APPLICATION_CREDENTIALS at your
# service account JSON; never commit that file (gitignored).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-2.5-flash

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///./promptshield.db

# fast = static + dataflow only; full = Gemini + vector enrich when project is set
PROMPTSHIELD_SCAN_MODE=fast

SCAN_RATE_LIMIT=10
SCAN_RATE_WINDOW=60
MAX_INPUT_CHARS=50000
REDACT_PERSISTED_INPUT=true
LOG_LEVEL=INFO
DASHBOARD_BASE_URL=http://localhost:5173

# --- MongoDB ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=promptshield
PRIMARY_STORE=mongo

# Optional: MONGODB_TLS_CA_FILE=...   MONGODB_TLS_ALLOW_INVALID=false (dev only)

# --- Embeddings (dims must match Atlas index definitions) ---
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMS=1024
VOYAGE_API_KEY=

# --- GitHub App (PR bot) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_FAST_SCAN=true
GITHUB_WEBHOOK_AI_ENRICHMENT=false
RISK_GATE_THRESHOLD=70

# --- Bootstrap admin (only if users collection is empty) ---
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Admin

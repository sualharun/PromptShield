# ─────────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — leave unset to skip the AI layer (static-only mode)
ANTHROPIC_API_KEY=

# Model used by the AI layer
AI_MODEL=claude-sonnet-4-20250514

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (SQLite by default; set to a postgresql:// URL for Postgres)
DATABASE_URL=sqlite:///./promptshield.db

# Rate limit on POST /api/scan (per client IP)
SCAN_RATE_LIMIT=10
SCAN_RATE_WINDOW=60

# Max input characters
MAX_INPUT_CHARS=50000

# Redact secrets/PII before persisting raw prompt text to DB
REDACT_PERSISTED_INPUT=true

# Logging
LOG_LEVEL=INFO

# Public URL of the React dashboard (used in PR Check Run "details" links)
DASHBOARD_BASE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# GitHub App (optional — required only for the PR review bot)
# Create at https://github.com/settings/apps/new
# ─────────────────────────────────────────────────────────────────────────────

# Numeric App ID shown on the App's settings page
GITHUB_APP_ID=

# Either paste the PEM private key inline (newlines preserved) ...
GITHUB_APP_PRIVATE_KEY=

# ... or point to a .pem file on disk (takes precedence over the inline var)
GITHUB_APP_PRIVATE_KEY_PATH=

# Webhook secret you set when creating the App (used for HMAC signature verify)
GITHUB_WEBHOOK_SECRET=

# Check Run fails when scan risk_score >= this threshold (0–100)
RISK_GATE_THRESHOLD=70

# ─────────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — leave unset to skip the AI layer (static-only mode)
ANTHROPIC_API_KEY=

# Model used by the AI layer
AI_MODEL=claude-sonnet-4-20250514

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Path to a legacy SQLite file — only used by scripts/migrate_sqlite_to_mongo.py
DATABASE_URL=sqlite:///./promptshield.db

# Rate limit on POST /api/scan (per client IP)
SCAN_RATE_LIMIT=10
SCAN_RATE_WINDOW=60

# Max input characters
MAX_INPUT_CHARS=50000

# Redact secrets/PII before persisting raw prompt text to DB
REDACT_PERSISTED_INPUT=true

# Logging
LOG_LEVEL=INFO

# Public URL of the React dashboard (used in PR Check Run "details" links)
DASHBOARD_BASE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# MongoDB Atlas
# ─────────────────────────────────────────────────────────────────────────────
# Free cluster: https://cloud.mongodb.com → Database Access (user+password) →
# Network Access (e.g. 0.0.0.0/0 for hackathon) → Connect → Drivers → copy SRV.
# If the DB password contains @ : / ? # use URL-encoding (urllib.parse.quote_plus).

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=promptshield

# If you see CERTIFICATE_VERIFY_FAILED on macOS: `pip install certifi` (included in requirements.txt).
# Override CA bundle path only if you know you need it:
# MONGODB_TLS_CA_FILE=/path/to/cacert.pem
# Dev-only escape hatch (insecure — never in prod):
# MONGODB_TLS_ALLOW_INVALID=false

# Telemetry / health only (backing store is always Mongo in production)
PRIMARY_STORE=mongo

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings (Atlas Vector Search)
# ─────────────────────────────────────────────────────────────────────────────
# voyage → Voyage AI (https://api.voyageai.com) — key from Voyage dashboard (MongoDB org)
# local  → sentence-transformers, no key, 384 dims — must match Atlas index if used
#
# EMBEDDING_DIMS must match scripts/atlas_indexes/*_idx.json "numDimensions"
#   voyage-3-large default → 1024
#   all-MiniLM-L6-v2       → 384

EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMS=1024

# Voyage: Project → API keys → Create new secret key (prefix pa-). No quotes unless the value has spaces.
VOYAGE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# GitHub App (optional — required only for the PR review bot)
# Create at https://github.com/settings/apps/new
# ─────────────────────────────────────────────────────────────────────────────

# Numeric App ID shown on the App's settings page
GITHUB_APP_ID=

# Either paste the PEM private key inline (newlines preserved) ...
GITHUB_APP_PRIVATE_KEY=

# ... or point to a .pem file on disk (takes precedence over the inline var)
GITHUB_APP_PRIVATE_KEY_PATH=

# Webhook secret you set when creating the App (used for HMAC signature verify)
GITHUB_WEBHOOK_SECRET=

# Check Run fails when scan risk_score >= this threshold (0–100)
RISK_GATE_THRESHOLD=70
